{
  "repoRoot": "/absolute/path/to/PhotoMapperAI",
  "outputRoot": "/absolute/path/to/external-validation/Validation_Run",
  "mapTimeoutSec": 600,
  "generateTimeoutSec": 1200,
  "continueOnError": true,
  "map": {
    "nameModel": "ollama:qwen2.5:7b",
    "confidenceThreshold": 0.9
  },
  "generate": {
    "format": "jpg",
    "faceDetectionModel": "opencv-dnn",
    "portraitOnly": false,
    "downloadOpenCvModels": true
  },
  "teams": [
    {
      "name": "Spain",
      "sourcePlayersCsvPath": "/absolute/path/to/external-validation/DataPrep/03_transformed_with_map_data/Spain.csv",
      "inputPhotosDir": "/absolute/path/to/external-validation/inputs/Spain",
      "expectedPortraitsDir": "/absolute/path/to/external-validation/expected/portraits/Spain"
    },
    {
      "name": "Switzerland",
      "sourcePlayersCsvPath": "/absolute/path/to/external-validation/DataPrep/03_transformed_with_map_data/Switzerland.csv",
      "inputPhotosDir": "/absolute/path/to/external-validation/inputs/Switzerland",
      "expectedPortraitsDir": "/absolute/path/to/external-validation/expected/portraits/Switzerland"
    }
  ]
}
