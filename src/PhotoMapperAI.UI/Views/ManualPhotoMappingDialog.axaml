<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PhotoMapperAI.UI.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="PhotoMapperAI.UI.Views.ManualPhotoMappingDialog"
        x:DataType="vm:ManualPhotoMappingDialogViewModel"
        Width="1320"
        Height="820"
        MinWidth="1100"
        MinHeight="720"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        Title="{Binding Title}">

  <Grid Margin="16" RowDefinitions="Auto,*,Auto,Auto" RowSpacing="12">
    <StackPanel Grid.Row="0" Spacing="4">
      <TextBlock Text="{Binding Title}"
                 FontSize="20"
                 FontWeight="Bold"
                 Foreground="{DynamicResource PrimaryBrush}"/>
      <TextBlock Text="Click one unmapped player, then click one unused photo. Review the preview, then click Add Mapping to queue it. Save writes the mapped CSV."
                 FontSize="12"
                 TextWrapping="Wrap"
                 Foreground="{DynamicResource SecondaryTextBrush}"/>
      <TextBlock Text="{Binding StatusMessage}"
                 FontSize="11"
                 TextWrapping="Wrap"
                 Foreground="{DynamicResource SecondaryTextBrush}"/>
    </StackPanel>

    <Grid Grid.Row="1" ColumnDefinitions="1.1*,1.2*,1.2*" ColumnSpacing="12">
      <Border Grid.Column="0" Background="{DynamicResource SurfaceBrush}" CornerRadius="8" Padding="12">
        <Grid RowDefinitions="Auto,*" RowSpacing="8">
          <TextBlock Grid.Row="0"
                     Text="{Binding UnmappedCount, StringFormat='Unmapped Players ({0})'}"
                     FontSize="13"
                     FontWeight="SemiBold"
                     Foreground="{DynamicResource PrimaryTextBrush}"/>
          <ListBox Grid.Row="1"
                   ItemsSource="{Binding UnmappedPlayers}"
                   SelectedItem="{Binding SelectedPlayer, Mode=TwoWay}">
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="vm:ManualMappingPlayerItem">
                <Border Padding="8" Margin="0,0,0,6" Background="{DynamicResource CardBrush}" CornerRadius="6">
                  <StackPanel Spacing="2">
                    <TextBlock Text="{Binding FullName}" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding Subtitle}" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"/>
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Grid>
      </Border>

      <Border Grid.Column="1" Background="{DynamicResource SurfaceBrush}" CornerRadius="8" Padding="12">
        <Grid RowDefinitions="Auto,*" RowSpacing="8">
          <TextBlock Grid.Row="0"
                     Text="{Binding AvailablePhotoCount, StringFormat='Unused Photos ({0})'}"
                     FontSize="13"
                     FontWeight="SemiBold"
                     Foreground="{DynamicResource PrimaryTextBrush}"/>
          <ListBox Grid.Row="1"
                   ItemsSource="{Binding AvailablePhotos}"
                   SelectedItem="{Binding SelectedPhoto, Mode=TwoWay}">
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="vm:ManualMappingPhotoItem">
                <Border Padding="8" Margin="0,0,0,6" Background="{DynamicResource CardBrush}" CornerRadius="6">
                  <StackPanel Spacing="2">
                    <TextBlock Text="{Binding FileName}" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding Subtitle}" FontSize="11" TextWrapping="Wrap" Foreground="{DynamicResource SecondaryTextBrush}"/>
                    <TextBlock Text="{Binding Source, StringFormat='Source: {0}'}" FontSize="10" Foreground="{DynamicResource SecondaryTextBrush}"/>
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Grid>
      </Border>

      <Border Grid.Column="2" Background="{DynamicResource SurfaceBrush}" CornerRadius="8" Padding="12">
        <StackPanel Spacing="8">
          <TextBlock Text="Review Selected Mapping"
                     FontSize="13"
                     FontWeight="SemiBold"
                     Foreground="{DynamicResource PrimaryTextBrush}"/>

          <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="10">
            <Grid ColumnDefinitions="110,*" RowDefinitions="Auto,Auto" RowSpacing="4">
              <TextBlock Grid.Row="0" Grid.Column="0" Text="Player:" Foreground="{DynamicResource SecondaryTextBrush}"/>
              <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedPlayer.FullName}" TextWrapping="Wrap"/>
              <TextBlock Grid.Row="1" Grid.Column="0" Text="Player ID:" Foreground="{DynamicResource SecondaryTextBrush}"/>
              <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedPlayer.PlayerId}" TextWrapping="Wrap"/>
            </Grid>
          </Border>

          <Button Content="Approve Mapping"
                  Command="{Binding QueueSelectedAssignmentCommand}"
                  IsEnabled="{Binding CanQueueSelectedAssignment}"
                  Padding="12,6"
                  HorizontalAlignment="Left"
                  Background="{DynamicResource PrimaryBrush}"
                  Foreground="{DynamicResource HeaderTextBrush}"/>

          <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="6" MinHeight="320">
            <Image Source="{Binding SelectedPhotoPreview}"
                   MaxWidth="420"
                   MaxHeight="320"
                   Stretch="Uniform"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>
          </Border>

          <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="10">
            <Grid ColumnDefinitions="110,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="4">
              <TextBlock Grid.Row="0" Grid.Column="0" Text="Filename:" Foreground="{DynamicResource SecondaryTextBrush}"/>
              <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedPhoto.FileName}" TextWrapping="Wrap"/>
              <TextBlock Grid.Row="1" Grid.Column="0" Text="External ID:" Foreground="{DynamicResource SecondaryTextBrush}"/>
              <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedPhoto.External_Player_ID}" TextWrapping="Wrap"/>
              <TextBlock Grid.Row="2" Grid.Column="0" Text="Full Name:" Foreground="{DynamicResource SecondaryTextBrush}"/>
              <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedPhoto.FullName}" TextWrapping="Wrap"/>
              <TextBlock Grid.Row="3" Grid.Column="0" Text="Source:" Foreground="{DynamicResource SecondaryTextBrush}"/>
              <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedPhoto.Source}" TextWrapping="Wrap"/>
              <TextBlock Grid.Row="4" Grid.Column="0" Text="Path:" Foreground="{DynamicResource SecondaryTextBrush}"/>
              <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SelectedPhoto.FilePath}" TextWrapping="Wrap"/>
            </Grid>
          </Border>
        </StackPanel>
      </Border>
    </Grid>

    <Border Grid.Row="2" Background="{DynamicResource SurfaceBrush}" CornerRadius="8" Padding="12">
      <Grid RowDefinitions="Auto,*" RowSpacing="8">
        <TextBlock Grid.Row="0"
                   Text="Queued Manual Mappings"
                   FontSize="13"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource PrimaryTextBrush}"/>
        <ItemsControl Grid.Row="1" ItemsSource="{Binding PendingAssignments}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:ManualMappingAssignmentItem">
              <Border Background="{DynamicResource CardBrush}" CornerRadius="6" Padding="8" Margin="0,0,0,6">
                <Grid ColumnDefinitions="2*,2*,Auto" ColumnSpacing="8">
                  <StackPanel Grid.Column="0" Spacing="2">
                    <TextBlock Text="{Binding Player.FullName}" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding Player.Subtitle}" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"/>
                  </StackPanel>
                  <StackPanel Grid.Column="1" Spacing="2">
                    <TextBlock Text="{Binding Photo.FileName}" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding Photo.Subtitle}" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap"/>
                  </StackPanel>
                  <Button Grid.Column="2"
                          Content="Undo"
                          Click="Undo_Click"
                          Padding="12,6"/>
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </Grid>
    </Border>

    <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
      <Button Content="Close"
              Click="Close_Click"
              Padding="18,8"/>
      <Button Content="Save Mappings"
              Click="Save_Click"
              IsEnabled="{Binding HasPendingAssignments}"
              Padding="18,8"
              Background="{DynamicResource SuccessBrush}"
              Foreground="{DynamicResource HeaderTextBrush}"/>
    </StackPanel>
  </Grid>
</Window>
